{
  "name": "pedagogo-ai",
  "version": "1.0.0",
  "description": "PEDAGOGO.AI — Automação Pedagógica Google Workspace for Education | Colégio Municipal de Itabatan | SEME/Mucuri-BA",
  "scripts": {
    "push":   "clasp push --force",
    "pull":   "clasp pull",
    "open":   "clasp open",
    "status": "clasp status",
    "logs":   "clasp logs --watch",
    "watch":  "clasp push --watch --force",
    "deploy": "clasp deploy --description \"Deploy $(date '+%d/%m/%Y %H:%M')\""
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83"
  }
}
